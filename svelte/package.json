{
  "name": "zengine-svelte",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:restart": "fuser -k 5173/tcp || true && vite",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"options_missing_custom_element:ignore\"",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --compiler-warnings \"options_missing_custom_element:ignore\"",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "lint": "run-p lint:eslint lint:stylelint",
    "lint:fix": "run-p lint:eslint:fix lint:stylelint:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@mdi/js": "^7.4.47",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@uiw/codemirror-extensions-color": "^4.25.9",
    "autolinker": "^4.1.5",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^2.36.0",
    "lowlight": "^3.3.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/eslint-plugin": "1.6.6",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.9.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-order": "^7.0.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
