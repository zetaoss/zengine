{
  "name": "zengine-skin-svelte",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:restart": "fuser -k 5174/tcp || true && sleep 1 && vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "watch": "vite build --watch",
    "build-only": "vite build",
    "type-check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "run-p lint:eslint lint:stylelint",
    "lint:fix": "run-p lint:eslint:fix lint:stylelint:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix"
  },
  "dependencies": {
    "autolinker": "^4.1.5",
    "dompurify": "^3.4.3",
    "isomorphic-dompurify": "^2.36.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "clsx": "^2.1.1",
    "eslint": "^10.4.0",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.17.1",
    "esm-env": "^1.2.2",
    "globals": "^17.5.0",
    "npm-run-all2": "^8.0.4",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.3"
  }
}
